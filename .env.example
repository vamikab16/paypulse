# PayPulse Environment Variables
# Copy this file to .env and fill in values as needed

# Server Configuration
PAYPULSE_HOST=0.0.0.0
PAYPULSE_PORT=8000

# Data Configuration
DATA_DIR=data
REGENERATE_DATA=false

# Security
# "production" enforces API key + stricter CORS; "development" keeps demo defaults
PAYPULSE_ENV=development
# Required when PAYPULSE_ENV=production (any non-empty string is accepted as secret)
PAYPULSE_API_KEY=

# Groq API Key (free tier — get one at https://console.groq.com)
# Used for AI behavioural insights on SME dashboards.
# Feature degrades gracefully to heuristic fallback if not set.
GROQ_API_KEY=

# Demo login credentials (previously kept in judges_credentials.txt — do NOT commit)
DEMO_USER_EMAIL=admin@nat
DEMO_USER_PASSWORD=change-me
